---
import Footer from "@/components/Footer.astro";
import Header from "@/components/Header.astro";
import Layout from "@/layouts/Layout.astro";
import Main from "@/layouts/Main.astro";
---

<Layout title="Work" description="Companies and organizations.">
  <Header />
  <Main pageTitle="Work" pageDesc="Companies and organizations">
  <div class="work-grid">

  <!-- VDART -->
  <article class="work-card">
    <img class="work-image" src="/images/companies/vdart-inc-dp-twitter.png" alt="VDART" />
    <h3>VDART</h3>
    <p>
      Parent Company, Founded 2007. Workforce Solutions, Talent Management, Contingent Labor Services.
      Specializes in Niche IT Talent, SMAC and Digital Technologies for Automotive & Mobility, Banking & Finance, Energy & Utility.
    </p>
  </article>

  <!-- VDart Digital -->
  <article class="work-card">
    <img class="work-image" src="/images/companies/VDart_Digital_Logo.jpg" alt="VDart Digital" />
    <h3>VDart Digital</h3>
    <p>
      Digital solutions and product firm focusing on AI & Agentic AI, Data & Analytics, Cloud, Cybersecurity, Blockchain,
      Enterprise SaaS, Quality Engineering, and Supply Chain.
    </p>
  </article>

  <!-- BeRecognized -->
  <article class="work-card">
    <img class="work-image" src="/images/companies/berecognized.png" alt="BeRecognized" />
    <h3>BeRecognized</h3>
    <p>
      Continuous digital identity platform with multi-layered verification and patented biometric identity technology.
      Provides an integrated identity suite for trust.
    </p>
  </article>

  <!-- VerifiedID -->
  <article class="work-card">
    <img class="work-image" src="/images/companies/verifiedid.png" alt="VerifiedID" />
    <h3>VerifiedID</h3>
    <p>
      Portable identity-bound background verification platform with continuous monitoring,
      fraud prevention, and compliance solutions.
    </p>
  </article>

  <!-- VDart BPM -->
  <article class="work-card">
    <img class="work-image" src="/images/companies/vdart-bpm.png" alt="VDart BPM" />
    <h3>VDart BPM</h3>
    <p>
      Non-IT workforce management specializing in call center offshoring and GCC capability.
    </p>
  </article>

  <!-- VDart EPC -->
  <article class="work-card">
    <img class="work-image" src="/images/companies/vdart-epc.png" alt="VDart EPC" />
    <h3>VDart EPC</h3>
    <p>
      Engineering, Procurement, and Construction (EPC) staffing solutions.
    </p>
  </article>

  <!-- VDart Healthcare -->
  <article class="work-card">
    <img class="work-image" src="/images/companies/vdart-healthcare.png" alt="VDart Healthcare" />
    <h3>VDart Healthcare</h3>
    <p>
      Medical and long-term care staffing services for travel and on-site patient care.
    </p>
  </article>

  <!-- HiddenCurve -->
  <article class="work-card">
    <img class="work-image" src="/images/companies/OIP.jpg" alt="HiddenCurve" />
    <h3>HiddenCurve</h3>
    <p>
      High-growth branding agency offering creative staffing and digital marketing solutions.
    </p>
  </article>

  <!-- VDART Ventures -->
  <article class="work-card">
    <img class="work-image" src="/images/companies/vdart-ventures.png" alt="VDART Ventures" />
    <h3>VDART Ventures</h3>
    <p>
      Mergers & acquisition firm supporting early-stage startups with venture capital and growth strategy.
    </p>
  </article>

  <!-- Sidd Ahmed -->
  <article class="work-card">
    <img class="work-image" src="/images/companies/sidd-ahmed.png" alt="Sidd Ahmed" />
    <h3>Sidd Ahmed</h3>
    <p>
      #1 social media brand for IT staffing, entrepreneurship, and career development with 3M+ global followers.
    </p>
  </article>

  </div>
  </Main>
  <Footer />
</Layout>

<style>
  .work-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 2rem;
  }

  .work-card {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .work-image {
    aspect-ratio: 1 / 1;
    width: 100%;
    object-fit: contain;
    background: #f5f5f5;
    border-radius: 4px;
  }

  .work-card p {
    margin: 0;
    font-size: 0.95rem;
    line-height: 1.4;
  }

  @media (max-width: 900px) {
    .work-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 640px) {
    .work-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
